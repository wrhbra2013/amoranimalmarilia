<link rel="stylesheet" href="/static/css/castracao_dashboard.css">
<%- include("_header")-%>
<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>Central de Castração</h1>
        <p>Escolha o tipo de serviço de castração que melhor atende às suas necessidades. Todos os nossos serviços são realizados com profissionais qualificados e acessíveis.</p>
    </header>

    <div class="dashboard-buttons">
        <!-- Castração de Baixo Custo -->
        <div class="dashboard-card dashboard-card-highlighted">
            <div class="card-content">
                <div class="card-icon">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <h2 class="card-title">Castração de Baixo Custo</h2>
                <p class="card-description">
                    Serviço de castração contínua com valores subsidiados para tutores que desejam realizar o procedimento de forma econômica e segura.
                </p>
                <% if (user && user.isAdmin) { %>
                <form action="/castracao/admin/default-clinica" method="POST" class="mt-2 mb-2 p-2 border rounded bg-light">
                    <label class="form-label small fw-bold mb-1">Clínica Padrão (Admin)</label>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <select name="defaultClinicaBaixoCusto" class="form-select form-select-sm" style="max-width:220px;" onchange="updateEnderecoBaixoCusto()" id="select-default-clinica-baixo-custo">
                            <option value="">-- Nenhuma --</option>
                            <% if (clinicas && clinicas.length) { %>
                                <% clinicas.forEach(function(c) { %>
                                    <option value="<%= c.nome %>" <%= (typeof defaultClinicaBaixoCusto !== 'undefined' && defaultClinicaBaixoCusto === c.nome) ? 'selected' : '' %> data-endereco="<%= c.endereco ? c.endereco.replace(/"/g,'&quot;') : '' %>"><%= c.nome %></option>
                                <% }); %>
                            <% } %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">Salvar</button>
                    </div>
                    <small class="text-muted">Endereço:</small>
                    <div id="default-clinica-baixo-custo-endereco" style="font-weight:500; font-size:0.85rem;"> <%= (typeof defaultClinicaBaixoCustoEndereco !== 'undefined' && defaultClinicaBaixoCustoEndereco) ? defaultClinicaBaixoCustoEndereco : ((typeof defaultClinicaBaixoCusto !== 'undefined' && defaultClinicaBaixoCusto) ? 'Endereço não cadastrado' : '— A definir —') %> </div>
                </form>
                <% } %>
                <a href="/castracao/baixo-custo" class="btn-dashboard btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Agendar Castração
                </a>
            </div>
        </div>

        <!-- Mutirão de Castração -->
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h2 class="card-title">Calendário de Mutirão</h2>
                <p class="card-description">
                    Eventos especiais com condições diferenciadas para castração em grupo. Acompanhe nosso calendário para participar do próximo mutirão.
                </p>
                <a href="/castracao/calendario-mutirao" class="btn-dashboard btn-secondary">
                    <i class="bi bi-calendar-event me-2"></i>Ver Calendário de Mutirões
                </a>
            </div>
        </div>

        <!-- Pets de Rua -->
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="bi bi-heart-fill"></i>
                </div>
                <h2 class="card-title">Pets de Rua</h2>
                <p class="card-description">
                    Programa especial para castração de animais de rua. Trabalhamos com protetores e voluntários para controlar a população de animais abandonados.
                </p>
                <% if (user && user.isAdmin) { %>
                <form action="/castracao/admin/default-clinica" method="POST" class="mt-2 mb-2 p-2 border rounded bg-light">
                    <label class="form-label small fw-bold mb-1">Clínica Padrão (Admin)</label>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <select name="defaultClinicaPetsRua" class="form-select form-select-sm" style="max-width:220px;" onchange="updateEnderecoPetsRua()" id="select-default-clinica-pets-rua">
                            <option value="">-- Nenhuma --</option>
                            <% if (clinicas && clinicas.length) { %>
                                <% clinicas.forEach(function(c) { %>
                                    <option value="<%= c.nome %>" <%= (typeof defaultClinicaPetsRua !== 'undefined' && defaultClinicaPetsRua === c.nome) ? 'selected' : '' %> data-endereco="<%= c.endereco ? c.endereco.replace(/"/g,'&quot;') : '' %>"><%= c.nome %></option>
                                <% }); %>
                            <% } %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">Salvar</button>
                    </div>
                    <small class="text-muted">Endereço:</small>
                    <div id="default-clinica-pets-rua-endereco" style="font-weight:500; font-size:0.85rem;"> <%= (typeof defaultClinicaPetsRuaEndereco !== 'undefined' && defaultClinicaPetsRuaEndereco) ? defaultClinicaPetsRuaEndereco : ((typeof defaultClinicaPetsRua !== 'undefined' && defaultClinicaPetsRua) ? 'Endereço não cadastrado' : '— A definir —') %> </div>
                </form>
                <% } %>
                <a href="/castracao/pets-rua" class="btn-dashboard btn-info">
                    <i class="bi bi-house-heart me-2"></i>Cadastrar Pet de Rua
                </a>
            </div>
        </div>
    </div>

<%- include("_footer")-%>

<script>
    function updateEnderecoBaixoCusto() {
        const select = document.getElementById('select-default-clinica-baixo-custo');
        if (!select) return;
        const enderecoDiv = document.getElementById('default-clinica-baixo-custo-endereco');
        const selectedOption = select.options[select.selectedIndex];
        const endereco = selectedOption.getAttribute('data-endereco');
        enderecoDiv.textContent = endereco || (select.value ? 'Endereço não cadastrado' : '— A definir —');
    }
    function updateEnderecoPetsRua() {
        const select = document.getElementById('select-default-clinica-pets-rua');
        if (!select) return;
        const enderecoDiv = document.getElementById('default-clinica-pets-rua-endereco');
        const selectedOption = select.options[select.selectedIndex];
        const endereco = selectedOption.getAttribute('data-endereco');
        enderecoDiv.textContent = endereco || (select.value ? 'Endereço não cadastrado' : '— A definir —');
    }
</script>