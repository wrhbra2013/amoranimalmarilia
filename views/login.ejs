<%-include("_semmenu")-%>

    <div class="container">
        <a href="/" class="btn btn-primary">Voltar para a página inicial</a>
    </div>

    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7">
                <div class="card">
                    <h3 class="text-center">Acesso ao Sistema</h3>
                </div>
                <div class="card-body">
                    <form action="/auth/login" method="post">
                        <div class="mb-3">
                            <label for="usuario" class="form-label">Usuário:</label>
                            <input type="text" id="usuario" name="usuario" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label for="senha" class="form-label">Senha:</label>
                            <div style="position: relative;">
                                <input type="password" id="senha" name="senha" class="form-control" required style="padding-right: 40px;">
                                <span onclick="document.getElementById('senha').type = document.getElementById('senha').type === 'password' ? 'text' : 'password'" 
                                      style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; user-select: none;">
                                    👁
                                </span>
                            </div>
                            <div class="form-check mt-2">
                                <input type="checkbox" class="form-check-input" id="mostrarSenha" 
                                    onchange="document.getElementById('senha').type = this.checked ? 'text' : 'password'">
                                <label class="form-check-label" for="mostrarSenha">Mostrar Senha</label>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Login</button>
                        </div>
                    </form>
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-danger mt-3">
                            <%= error %>
                        </div>
                    <% } %>
                </div>
                <div class="card-footer text-center">
                    <p class="mb-0"></p>
                </div>
            </div>
        </div>
    </div>

<%-include("_footer")-%>
