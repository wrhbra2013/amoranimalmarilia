<%- include("_header") -%>

<main class="container mt-4">
  <h1>Inscrição para Mutirão de Castração</h1>
  <p class="text-muted">Preencha os dados abaixo para inscribirse no mutirão de castração.</p>

  <% if (error && error.length) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success && success.length) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <section class="card mb-4 p-3">
    <form action="/castracao/mutirao-inscricao" method="POST" id="formInscricao">
      <input type="hidden" name="calendario_mutirao_id" value="<%= mutirao.id %>">
      
      <h4>Dados do Responsável</h4>
      
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Nome do Responsável *</label>
          <input type="text" name="nome_responsavel" id="nomeResponsavel" class="form-control" required>
        </div>
        
        <div class="col-md-3">
          <label class="form-label fw-bold">CPF *</label>
          <input type="text" name="cpf" id="cpf" class="form-control" placeholder="000.000.000-00" required>
        </div>
        
        <div class="col-md-3">
          <label class="form-label fw-bold">Contato *</label>
          <input type="tel" name="contato" id="contato" class="form-control phone-input" placeholder="(00) 00000-0000" required>
        </div>
      </div>
      
      <div class="row g-3 mb-3">
        <div class="col-md-3">
          <label class="form-label">CEP *</label>
          <div class="input-group">
            <input type="text" name="cep" id="cep" class="form-control" placeholder="00000-000" required>
            <button type="button" class="btn btn-outline-secondary" onclick="buscarCep()" title="Buscar CEP">
              <i class="bi bi-search"></i>
            </button>
          </div>
        </div>
        
        <div class="col-md-5">
          <label class="form-label">Endereço</label>
          <input type="text" name="endereco" id="endereco" class="form-control" placeholder="Rua/Logradouro">
        </div>
        
        <div class="col-md-2">
          <label class="form-label">Número</label>
          <input type="text" name="numero" id="numero" class="form-control" placeholder="Nº">
        </div>
        
        <div class="col-md-2">
          <label class="form-label">Complemento</label>
          <input type="text" name="complemento" id="complemento" class="form-control" placeholder="Apto/Bloco">
        </div>
      </div>
      
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label">Bairro</label>
          <input type="text" name="bairro" id="bairro" class="form-control" placeholder="Bairro">
        </div>
        
        <div class="col-md-4">
          <label class="form-label">Cidade</label>
          <input type="text" name="cidade" id="cidade" class="form-control" placeholder="Cidade">
        </div>
        
        <div class="col-md-2">
          <label class="form-label">Estado</label>
          <input type="text" name="estado" id="estado" class="form-control" placeholder="UF" maxlength="2">
        </div>
      </div>

      <hr>

      <h4>Dados dos Pets</h4>
      <p class="text-muted">Cada pet cadastrado ocupará uma vaga no mutirão.</p>

      <!-- Formulário para adicionar pet -->
      <div class="card bg-light p-3 mb-3">
        <div class="row g-2">
          <div class="col-md-3">
            <label class="form-label">Nome do Pet *</label>
            <input type="text" id="petNome" class="form-control">
          </div>
          <div class="col-md-2">
            <label class="form-label">Espécie *</label>
            <select id="petEspecie" class="form-select">
              <option value="">Selecione...</option>
              <option value="gato">Gato</option>
              <option value="cachorro">Cachorro</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Sexo *</label>
            <select id="petSexo" class="form-select">
              <option value="">Selecione...</option>
              <option value="macho">Macho</option>
              <option value="femea">Fêmea</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Idade</label>
            <input type="text" id="petIdade" class="form-control" placeholder="Ex: 2 anos">
          </div>
          <div class="col-md-3">
            <label class="form-label">Peso</label>
            <input type="text" id="petPeso" class="form-control" placeholder="Ex: 4kg">
          </div>
          <div class="col-md-2">
            <label class="form-label">Vacinado?</label>
            <select id="petVacinado" class="form-select">
              <option value="false">Não</option>
              <option value="true">Sim</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Usa medicamento?</label>
            <select id="petTemMedicamento" class="form-select">
              <option value="nao">Não</option>
              <option value="sim">Sim</option>
            </select>
          </div>
          <div class="col-md-7" id="medicamentoField" style="display: none;">
            <label class="form-label">Qual medicamento?</label>
            <input type="text" id="petMedicamento" class="form-control" placeholder="Descreva o medicamento">
          </div>
        </div>
        <div class="row mt-3">
          <div class="col-12 text-end">
            <button type="button" class="btn btn-primary" id="btnAddPet">
              <i class="bi bi-plus-lg"></i> Adicionar Pet
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de pets adicionados -->
      <h4>Pets Cadastrados (<span id="petCount">0</span>)</h4>

      <div class="row mb-3">
        <div class="col-12">
          <div id="petsTableContainer">
            <p class="text-muted text-center p-3">Nenhum pet cadastrado ainda.</p>
          </div>
        </div>
      </div>

      <!-- Campos ocultos para os pets -->
      <input type="hidden" name="pets_json" id="petsJson">

      <!-- Botão de submit -->
      <div class="row mb-3">
        <div class="col-md-12 text-end">
          <button type="submit" class="btn btn-primary btn-lg" id="btnSubmit" disabled>
            <i class="bi bi-check-lg"></i> Realizar Inscrição
          </button>
        </div>
      </div>
    </form>
  </section>

  <div class="card">
    <div class="card-body">
      <h5>Informações do Mutirão</h5>
      <p><strong>Data:</strong> <%= mutirao.data_evento ? new Date(mutirao.data_evento).toLocaleDateString('pt-BR') : '' %></p>
      <p><strong>Clínica:</strong> <%= mutirao.clinica %></p>
      <% if (mutirao.endereco) { %>
        <p><strong>Endereço:</strong> <%= mutirao.endereco %></p>
      <% } %>
      <p><strong>Vagas:</strong> <%= mutirao.vagas === 0 ? 'Ilimitadas' : mutirao.vagas %></p>
      <% if (mutirao.vagas_disponiveis !== null) { %>
        <p><strong>Vagas disponíveis:</strong> <span class="badge bg-info"><%= mutirao.vagas_disponiveis %></span></p>
      <% } %>
    </div>
  </div>
</main>

<script>
(function() {
    var pets = [];
    
    var petTemMedicamento = document.getElementById('petTemMedicamento');
    var medicamentoField = document.getElementById('medicamentoField');
    var btnAddPet = document.getElementById('btnAddPet');
    var btnSubmit = document.getElementById('btnSubmit');
    var petCount = document.getElementById('petCount');
    var petsTableContainer = document.getElementById('petsTableContainer');
    var petsJson = document.getElementById('petsJson');
    
    petTemMedicamento.addEventListener('change', function() {
        medicamentoField.style.display = this.value === 'sim' ? 'block' : 'none';
    });
    
    btnAddPet.addEventListener('click', function() {
        var nome = document.getElementById('petNome').value.trim();
        var especie = document.getElementById('petEspecie').value;
        var sexo = document.getElementById('petSexo').value;
        
        if (!nome || !especie || !sexo) {
            alert('Preencha: Nome, Espécie e Sexo do pet');
            return;
        }
        
        pets.push({
            nome: nome,
            especie: especie,
            sexo: sexo,
            idade: document.getElementById('petIdade').value || '',
            peso: document.getElementById('petPeso').value || '',
            vacinado: document.getElementById('petVacinado').value === 'true',
            medicamento: petTemMedicamento.value === 'sim' ? document.getElementById('petMedicamento').value : ''
        });
        
        document.getElementById('petNome').value = '';
        document.getElementById('petEspecie').value = '';
        document.getElementById('petSexo').value = '';
        document.getElementById('petIdade').value = '';
        document.getElementById('petPeso').value = '';
        document.getElementById('petVacinado').value = 'false';
        petTemMedicamento.value = 'nao';
        medicamentoField.style.display = 'none';
        document.getElementById('petMedicamento').value = '';
        
        atualizarTabela();
    });
    
    function atualizarTabela() {
        petCount.textContent = pets.length;
        petsJson.value = JSON.stringify(pets);
        btnSubmit.disabled = pets.length === 0;
        btnSubmit.textContent = pets.length === 0 ? 'Adicione um pet primeiro' : 'Realizar Inscrição';
        
        if (pets.length === 0) {
            petsTableContainer.innerHTML = '<p class="text-muted text-center p-3">Nenhum pet cadastrado ainda.</p>';
            return;
        }
        
        var html = '<table class="table table-sm table-hover"><thead><tr>';
        html += '<th>#</th><th>Nome</th><th>Espécie</th><th>Sexo</th><th>Idade</th><th>Peso</th><th>Vacinado</th><th>Ações</th>';
        html += '</tr></thead><tbody>';
        
        pets.forEach(function(pet, index) {
            html += '<tr>';
            html += '<td>' + (index + 1) + '</td>';
            html += '<td><strong>' + pet.nome + '</strong></td>';
            html += '<td>' + pet.especie + '</td>';
            html += '<td>' + pet.sexo + '</td>';
            html += '<td>' + (pet.idade || '-') + '</td>';
            html += '<td>' + (pet.peso || '-') + '</td>';
            html += '<td>' + (pet.vacinado ? '<span class="badge bg-success">Sim</span>' : '<span class="badge bg-danger">Não</span>') + '</td>';
            html += '<td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removerPet(' + index + ')"><i class="bi bi-trash"></i></button></td>';
            html += '</tr>';
        });
        
        html += '</tbody></table>';
        petsTableContainer.innerHTML = html;
    }
    
    window.removerPet = function(index) {
        if (confirm('Remover este pet?')) {
            pets.splice(index, 1);
            atualizarTabela();
        }
    };
    
    document.getElementById('formInscricao').addEventListener('submit', function(e) {
        if (pets.length === 0) {
            e.preventDefault();
            alert('Adicione pelo menos um pet');
            return;
        }
        petsJson.value = JSON.stringify(pets);
    });
    
    // Função para buscar CEP
    window.buscarCep = function() {
        var cep = document.getElementById('cep').value.replace(/\D/g, '');
        
        if (cep.length !== 8) {
            alert('CEP inválido. Digite 8 dígitos.');
            return;
        }
        
        fetch('https://viacep.com.br/ws/' + cep + '/json/')
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.erro) {
                    alert('CEP não encontrado.');
                    return;
                }
                document.getElementById('endereco').value = data.logradouro || '';
                document.getElementById('bairro').value = data.bairro || '';
                document.getElementById('cidade').value = data.localidade || '';
                document.getElementById('estado').value = data.uf || '';
            })
            .catch(function(error) {
                console.error('Erro ao buscar CEP:', error);
                alert('Erro ao buscar CEP. Tente novamente.');
            });
    };
    
    // Formatar CPF
    var cpfInput = document.getElementById('cpf');
    cpfInput.addEventListener('input', function(e) {
        var value = e.target.value.replace(/\D/g, '');
        if (value.length > 11) value = value.slice(0, 11);
        
        var formatted = '';
        if (value.length > 0) formatted = value.slice(0, 3);
        if (value.length > 3) formatted += '.' + value.slice(3, 6);
        if (value.length > 6) formatted += '.' + value.slice(6, 9);
        if (value.length > 9) formatted += '-' + value.slice(9, 11);
        
        e.target.value = formatted;
    });
    
    // Formatar CEP
    var cepInput = document.getElementById('cep');
    cepInput.addEventListener('input', function(e) {
        var value = e.target.value.replace(/\D/g, '');
        if (value.length > 8) value = value.slice(0, 8);
        
        var formatted = '';
        if (value.length > 0) formatted = value.slice(0, 5);
        if (value.length > 5) formatted += '-' + value.slice(5, 8);
        
        e.target.value = formatted;
    });
    
    // Buscar CEP ao pressionar Enter
    document.getElementById('cep').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            buscarCep();
        }
    });
})();
</script>

<%- include("_footer") -%>
