<%- include("_header") -%>

<main class="main-content">
  <div class="container">
    <h2>Criar Evento</h2>

    <% if (typeof error_msg !== 'undefined' && error_msg.length) { %>
      <div class="alert" style="background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;"><%= error_msg %></div>
    <% } %>
    <% if (typeof success_msg !== 'undefined' && success_msg.length) { %>
      <div class="alert" style="background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb;"><%= success_msg %></div>
    <% } %>

    <form action="/eventos/form" method="post" enctype="multipart/form-data">
      <label for="titulo">Título</label>
      <input type="text" id="titulo" name="titulo" required>

      <label for="data">Data do Evento</label>
      <input type="date" id="data" name="data">

      <label for="arquivo">Imagem (obrigatória)</label>
      <input type="file" id="arquivo" name="arquivo" accept="image/*" required>

      <label for="descricao">Descrição</label>
      <textarea id="descricao" name="descricao" rows="6"></textarea>

      <div class="button-group">
        <a href="/eventos" class="button btn-cancelar">Cancelar</a>
        <button type="submit" class="button btn-submit-form">Criar Evento</button>
      </div>
    </form>

  </div>
</main>

<%- include("_footer") -%>
