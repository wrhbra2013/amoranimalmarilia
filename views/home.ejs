<% const eventsList = (typeof modelEventos !== 'undefined' && modelEventos.length) ? modelEventos : ((typeof model1 !== 'undefined' && model1.length) ? model1 : []); %>

<% if (eventsList && eventsList.length > 0) { %>
<!-- ==========================================================================
    EVENTOS - Cards com Carrossel de Fotos, Descrição e Comentários
========================================================================== -->
<section class="landing-section landing-section-white">
    <div class="landing-container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 style="color: var(--heading-color);">Eventos</h2>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <a href="/eventos/form" class="button btn-sm">+ Adicionar Evento</a>
            <% } %>
        </div>

        <div class="events-grid">
        <% eventsList.slice(0, 4).forEach(function(event, i) { 
            const imgSrc = event.arquivo ? ('/uploads/eventos/' + event.arquivo) : ('/uploads/home/' + (event.arquivo || 'placeholder-event.jpg'));
            const linkUrl = event.arquivo ? `/eventos/${event.id}` : `/campanha/${event.id}`;
            const eventDate = event.data_evento ? new Date(event.data_evento).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) : '';
            const hasFotos = event.fotos && event.fotos.length > 0;
        %>
        <div class="event-full-card">
            <div class="event-info">
                <h3 class="event-titulo"><%= event.titulo %></h3>
                <div class="event-meta">
                    <span><i class="fas fa-calendar-alt"></i> <%= eventDate %></span>
                    <% if (event.local) { %>
                    <span><i class="fas fa-map-marker-alt"></i> <%= event.local %></span>
                    <% } %>
                </div>
                <p class="event-descricao"><%= event.descricao ? event.descricao.substring(0, 600) + (event.descricao.length > 600 ? '...' : '') : 'Descrição não disponível.' %></p>
                
                <% if (event.comentarios && event.comentarios.length > 0) { %>
                <div class="event-comentarios">
                    <div class="event-comentarios-titulo">
                        <i class="fas fa-comments"></i> Comentários (<%= event.comentarios.length %>)
                    </div>
                    <% event.comentarios.slice(0, 2).forEach(function(comment) { %>
                    <div class="event-comment">
                        <div class="event-comment-autor"><%= comment.nome || 'Anônimo' %></div>
                        <div class="event-comment-texto"><%= comment.comentario %></div>
                    </div>
                    <% }); %>
                </div>
                <% } %>
            </div>
            <div class="event-fotos-carrossel">
                <div class="event-fotos-scroll" id="event-fotos-<%= i %>">
                    <% if (hasFotos) { %>
                        <% event.fotos.forEach(function(foto) { %>
                        <a href="/eventos/<%= event.id %>" class="event-foto-item">
                            <img src="/uploads/eventos/<%= foto.arquivo %>" alt="<%= event.titulo %>">
                        </a>
                        <% }); %>
                    <% } else { %>
                        <a href="<%= linkUrl %>" class="event-foto-item">
                            <img src="<%= imgSrc %>" alt="<%= event.titulo %>">
                        </a>
                    <% } %>
                </div>
                <% if (hasFotos && event.fotos.length > 1) { %>
                <button class="evt-foto-btn evt-foto-prev" onclick="scrollEventFotos(<%= i %>, -1)">‹</button>
                <button class="evt-foto-btn evt-foto-next" onclick="scrollEventFotos(<%= i %>, 1)">›</button>
                <% } %>
            </div>
        </div>
        <% }); %>
        </div>
    </div>
</section>
<% } %>

<% const hasCastracao = typeof model8 !== 'undefined' && model8.length > 0; %>

<% if (hasCastracao) { %>
<!-- ==========================================================================
    AGENDAMENTOS DE CASTRACÃO
========================================================================== -->
<section class="landing-section landing-section-alt">
    <div class="landing-container">
        <h2 class="text-center mb-4" style="color: var(--heading-color);">Agendamentos de Castração</h2>
        
        <div class="table-responsive" style="max-height: 400px; overflow-y: auto; border-radius: 12px; box-shadow: var(--container-shadow);">
            <table class="table table-striped table-hover mb-0">
                <thead style="position: sticky; top: 0; background: var(--brand-teal); color: white;">
                    <tr>
                        <th>Ticket</th>
                        <th>Nome Pet</th>
                        <th>Responsável</th>
                        <th>Espécie</th>
                        <th>Clínica</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th>Ações</th>
                        <th>Comprovante</th>
                    </tr>
                </thead>
                <tbody>
                    <% model8.slice(0, 10).forEach(function(castracao) { 
                        const statusUpper = castracao.status ? String(castracao.status).trim().toUpperCase() : 'PENDENTE';
                        const isAttended = statusUpper === 'ATENDIDO';
                        const rotaAtender = castracao.tipo === 'mutirao' ? '/castracao/mutirao/updateStatus/' + castracao.id : '/castracao/updateStatus/' + castracao.id;
                        const rotaComprovante = castracao.tipo === 'mutirao' ? '/castracao/mutirao/comprovante/' + castracao.ticket : '/castracao/comprovante/' + castracao.ticket;
                    %>
                    <tr id="castracao-row-<%= castracao.id %>">
                        <td><strong>#<%= castracao.ticket %></strong></td>
                        <td><%= castracao.nome_pet || '-' %></td>
                        <td><%= castracao.nome %></td>
                        <td><%= castracao.especie %></td>
                        <td><%= castracao.clinica %></td>
                        <td><%= castracao.data_evento ? new Date(castracao.data_evento).toLocaleDateString('pt-BR') : 'N/A' %></td>
                        <td class="status-cell">
                            <% if (isAttended) { %>
                                <span class="badge" style="background: #10b981; color: white;">ATENDIDO</span>
                            <% } else { %>
                                <span class="badge" style="background: #f59e0b; color: white;">PENDENTE</span>
                            <% } %>
                        </td>
                        <td class="acoes-cell">
                            <% if (!isAttended) { %>
                            <button type="button" class="btn btn-sm" style="background: #10b981; color: white; padding: 4px 8px; font-size: 0.75rem;" onclick="atenderCastracao('<%= rotaAtender %>', '<%= castracao.id %>')">
                                <i class="fas fa-check"></i> Atender
                            </button>
                            <% } else { %>
                            <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td class="comprovante-cell">
                            <% if (castracao.ticket) { %>
                            <a href="<%= rotaComprovante %>" target="_blank" class="btn btn-sm" style="background: var(--brand-teal); color: white; padding: 4px 8px; font-size: 0.75rem;">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                            <% } else { %>
                            <span class="text-muted">-</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        
        <div class="text-center mt-4">
            <a href="/castracao/" class="button">+ Novo Agendamento</a>
        </div>
    </div>
</section>
<% } %>

