<%-include("_header")-%>

<style>
.stat-card {
    background: var(--container-bg) !important;
}
/* Event Card com Hover */
.event-card-hover {
    position: relative;
    display: flex;
    flex-direction: row;
    gap: 20px;
    margin-bottom: 30px;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: var(--container-shadow);
    background: var(--container-bg);
}
.event-card-hover .event-info {
    flex: 2;
    padding: 20px;
    z-index: 2;
    overflow-y: auto;
    max-height: 350px;
    position: relative;
    z-index: 5;
    background: var(--container-bg);
}
.event-card-hover .event-fotos-area {
    flex: 1;
    position: relative;
    min-height: 300px;
    max-height: 350px;
    overflow: hidden;
    transition: flex 0.5s ease;
}
.event-card-hover:hover .event-fotos-area {
    flex: 0.4;
}
.event-card-hover:hover .event-fotos-area img {
    transform: scale(1.15);
}
.event-card-hover .event-fotos-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.5s ease;
    display: block;
}
.event-card-hover .event-fotos-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
}
.event-card-hover:hover .event-fotos-overlay {
    opacity: 1;
}
.event-fotos-overlay-text {
    color: white;
    font-size: 14px;
    padding: 10px 20px;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 20px;
}
/* Lightbox CSS Puro */
.event-lightbox {
    display: none;
}
.event-lightbox:checked + .event-lightbox-trigger + .event-lightbox-overlay {
    display: flex;
    opacity: 1;
    visibility: visible;
}
.event-lightbox-trigger {
    cursor: pointer;
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10;
}
.event-lightbox-trigger img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.event-lightbox-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease;
}
.event-lightbox-content {
    position: relative;
    max-width: 90%;
    max-height: 85%;
}
.event-lightbox-content img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
}
.event-lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: white;
    font-size: 40px;
    cursor: pointer;
    z-index: 10000;
}
.event-lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: white;
    font-size: 50px;
    cursor: pointer;
    padding: 20px;
}
.event-lightbox-prev { left: 20px; }
.event-lightbox-next { right: 20px; }
.event-lightbox-counter {
    color: white;
    margin-top: 15px;
    font-size: 14px;
}
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
.castracao-table {
    /* max-height removed to allow full expansion */
    /* overflow-y removed */
}
.castracao-table table {
    min-width: 500px;
}
.btn-atender, .btn-comprovante {
    padding: 2px 6px !important;
    font-size: 0.7rem !important;
    color: white !important;
    position: relative;
    margin-left: 4px;
}
.btn-atender { background: #10b981; }
.btn-comprovante { background: var(--brand-teal); }
.btn-atender:hover::after {
    content: "Atender";
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #333;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.7rem;
    white-space: nowrap;
    margin-bottom: 4px;
}
.btn-comprovante:hover::after {
    content: "PDF";
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #333;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.7rem;
    white-space: nowrap;
    margin-bottom: 4px;
}
</style>

<script>
function toggleArchivedRows(show) {
    document.querySelectorAll('.archived-row').forEach(function(row) {
        row.style.display = show ? 'table-row' : 'none';
    });
}
function toggleAttendedRows(show) {
    document.querySelectorAll('.attended-row').forEach(function(row) {
        row.style.display = show ? 'table-row' : 'none';
    });
}
function scrollEventFotos(index, direction) {
    const container = document.getElementById('event-fotos-' + index);
    if (container) {
        const scrollAmount = 400;
        container.scrollBy({
            left: direction * scrollAmount,
            behavior: 'smooth'
        });
    }
}
function atenderCastracao(url, rowId) {
    if (!confirm('Confirmar atendimento?')) return;
    
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
        if (xhr.status === 200) {
            var row = document.getElementById('castracao-row-' + rowId);
            if (row) {
                var cells = row.querySelectorAll('td');
                if (cells[6]) {
                    cells[6].innerHTML = '<span class="badge" style="background: #10b981; color: white;">✓ Atendido</span>';
                }
                if (cells[7]) {
                    cells[7].innerHTML = '';
                }
            }
        } else {
            alert('Erro ao processar atendimento.');
        }
    };
    xhr.send();
}
document.addEventListener('DOMContentLoaded', function() {
    toggleArchivedRows(false);
    toggleAttendedRows(false);
});
</script>

