                    const isMutirao = castracao.tipo === 'mutirao';
                    const especieIcon = (castracao.especie && castracao.especie.toLowerCase().includes('gato')) ? '🐈' : '🐕';
                    const rotaAtender = isMutirao ? '/castracao/mutirao/updateStatus/' + castracao.id : '/castracao/updateStatus/' + castracao.id;
                    const rotaComprovante = isMutirao ? '/castracao/mutirao/comprovante/' + castracao.ticket : '/castracao/comprovante/' + castracao.ticket;
