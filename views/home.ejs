                            <span class="badge" style="background: #10b981; color: white;">✓ Atendido</span>
                        <% } else { %>
                            <span class="badge" style="background: #f59e0b; color: white;">⏳ Pendente</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (!isAttended) { %>
                        <button type="button" class="btn btn-sm btn-atender" onclick="atenderCastracao('<%= rotaAtender %>', '<%= castracao.id %>')">
                            ✓
                        </button>
                        <% } %>
                        <% if (castracao.ticket) { %>
                        <a href="<%= rotaComprovante %>" target="_blank" class="btn btn-sm btn-comprovante">
                            📄
                        </a>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    
    <div class="landing-container">
        <div class="text-center mt-4">
            <a href="/castracao/" class="button button-highlight">+ Novo Agendamento</a>
        </div>
    </div>
</section>
<% } %>

<% if (typeof model2 !== 'undefined' && model2.length > 0) { %>
<!-- ==========================================================================
    ADOÇÃO - Carrossel de Fotos
========================================================================== -->
<section id="adocao-destaque" class="landing-section landing-section-white">
    <div class="landing-container">
        <h2 class="text-center mb-4" style="color: var(--heading-color);">Esperando por um Lar</h2>
        
        <div class="adocao-carrossel">
            <% model2.forEach(adocao => { %>
            <a href="/adocao/<%= adocao.id %>" class="adocao-card-simple">
                <img src="/uploads/adocao/<%= adocao.arquivo || 'placeholder-pet.jpg' %>"
                     alt="<%= adocao.nome || 'Pet para adoção' %>">
            </a>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<!-- ==========================================================================
    VOLUNTÁRIOS - Carrossel da Página Sobre
========================================================================== -->
<% if (typeof model14 !== 'undefined' && model14 && model14.length > 0) { %>
<section class="landing-section landing-section-alt">
    <div class="landing-container">
        <h2 class="text-center mb-4" style="color: var(--heading-color);">
            <i class="fas fa-hands-helping"></i> Nossos Voluntários
        </h2>
        <p class="text-center text-muted mb-4">Conheça as pessoas que fazem essa obra acontecer</p>
        
        <div class="voluntarios-carrossel">
            <% model14.slice(0, 12).forEach(function(v) { %>
            <a href="/doacao/voluntario" class="voluntario-card" style="text-decoration: none;">
                <div class="voluntario-card-avatar">
                    <% if (v.arquivo) { %>
                        <img src="/uploads/voluntario/<%= v.arquivo %>" alt="<%= v.nome %>">
                    <% } else { %>
                        <div class="avatar-initials"><%= v.nome ? v.nome.charAt(0).toUpperCase() : 'V' %></div>
                    <% } %>
                </div>
                <div class="voluntario-card-body">
                    <div class="voluntario-card-name"><%= v.nome ? (v.nome.length > 25 ? v.nome.slice(0, 23) + '..' : v.nome) : 'Voluntário' %></div>
                    <div class="voluntario-card-funcao"><i class="fas fa-paw"></i> <%= v.funcao || 'Voluntário' %></div>
                    <% if (v.localidade) { %>
                    <div class="voluntario-card-location">
                        <i class="fas fa-map-marker-alt"></i> <%= v.localidade %>
                    </div>
                    <% } %>
                    <% if (v.mensagem) { %>
                    <div class="voluntario-card-message">
                        "<%= v.mensagem.length > 80 ? v.mensagem.slice(0, 77) + '...' : v.mensagem %>"
                    </div>
                    <% } %>
                </div>
            </a>
            <% }); %>
        </div>
        
        <div class="text-center mt-4">
            <a href="/doacao/voluntario" class="button">Ver Todos os Voluntários</a>
        </div>
    </div>
</section>
<% } %>

<!-- ==========================================================================
    HISTÓRIAS DE ADOTADOS
========================================================================== -->
<% if (typeof model6 !== 'undefined' && model6.length > 0) { %>
<section class="landing-section landing-section-white">
    <div class="landing-container">
        <h2 class="text-center mb-4" style="color: var(--heading-color);">Histórias que Inspiram</h2>
        
        <div class="landing-grid">
            <% model6.slice(0, 3).forEach(adotado => { %>
            <div class="landing-card">
                <div class="landing-card-header" style="background: linear-gradient(135deg, var(--brand-purple), var(--brand-pink));">
                    <h3><%= adotado.pet %></h3>
                </div>
                <div class="landing-card-body" style="padding: 0;">
                    <img src="/uploads/adotado/<%= adotado.arquivo || 'placeholder-pet-story.jpg' %>"
                         alt="<%= adotado.pet %>"
                         style="width: 100%; height: 200px; object-fit: cover;">
                    <div style="padding: 1.25rem;">
                        <p class="text-muted small">Adotado por: <%= adotado.tutor %></p>
                        <p style="font-style: italic; color: var(--text-color);">"<%= adotado.historia ? adotado.historia.substring(0, 120) + (adotado.historia.length > 120 ? '...' : '') : '' %>"</p>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        
        <div class="text-center mt-4">
            <a href="/adotado" class="button">Ver Todas as Histórias</a>
            <% if (user) { %>
            <a href="/adotado/form" class="button ms-2" style="background: var(--brand-purple);">Adicionar História</a>
            <% } %>
        </div>
    </div>
</section>
<% } %>

<!-- ==========================================================================
    MISSÃO / SOBRE RESUMO
========================================================================== -->
<section class="landing-section landing-section-alt">
    <div class="landing-container">
        <div class="landing-grid" style="grid-template-columns: 1fr 1fr; align-items: center;">
            <div>
                <h2 style="color: var(--heading-color);">Nossa Missão</h2>
                <p style="line-height: 1.8; color: var(--text-color);">
                    A ONG Amor Animal é dedicada ao resgate, reabilitação e realocação de animais em situação de vulnerabilidade. 
                    Movidos pela compaixão, trabalhamos incansavelmente para oferecer uma segunda chance a cada um deles, 
                    promovendo a posse responsável e o bem-estar animal em nossa comunidade.
                </p>
                <a href="/sobre" class="button">Saiba Mais Sobre Nós</a>
            </div>
            <div style="text-align: center;">
                <fieldset style="border: 2px solid var(--brand-teal); border-radius: 12px; padding: 1.5rem; max-width: 300px; margin: 0 auto;">
                    <legend style="padding: 0 10px; font-weight: bold; color: var(--heading-color);">Portal da Transparência</legend>
                    <img src="/static/css/imagem/transparencia.png" alt="QR Code Transparência" style="width: 150px; height: 150px; border-radius: 8px;">
                    <p style="margin-top: 1rem; color: var(--text-color); font-size: 0.9rem;">
                        Escaneie ou visite<br>
                        <a href="https://amoranimal.ong.br/transparencia" target="_blank" style="color: var(--brand-teal);">amoranimal.ong.br/transparencia</a>
                    </p>
                </fieldset>
            </div>
        </div>
    </div>
</section>

<!-- ==========================================================================
    CHAMADA FINAL / COMO AJUDAR
========================================================================== -->
<section class="landing-section landing-section-white">
    <div class="landing-container text-center">
        <h2 style="color: var(--heading-color); margin-bottom: 1rem;">Faça Parte da Mudança</h2>
        <p style="font-size: 1.1rem; color: var(--text-color); margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
            Sua ajuda, seja como voluntário, parceiro ou doador, é fundamental para continuarmos nosso trabalho.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="/doacao/voluntario/interesse/form" class="button">Quero ser Voluntário</a>
            <a href="/parceria/form" class="button" style="background: var(--brand-coral);">Seja um Parceiro</a>
            <a href="/doacao" class="button" style="background: var(--brand-purple);">Faça uma Doação</a>
        </div>
    </div>
</section>

</main>

<%- include("_footer") -%>