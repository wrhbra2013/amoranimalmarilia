<% const eventsList = (typeof modelEventos !== 'undefined' && modelEventos.length) ? modelEventos : ((typeof model1 !== 'undefined' && model1.length) ? model1 : []); %>

<% if (eventsList && eventsList.length > 0) { %>
<!-- ==========================================================================
    EVENTOS - Cards com Carrossel de Fotos, Descrição e Comentários
========================================================================== -->
<section class="landing-section landing-section-white">
    <div class="landing-container">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 style="color: var(--heading-color);">Eventos</h2>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <a href="/eventos/form" class="button btn-sm">+ Adicionar Evento</a>
            <% } %>
        </div>

        <div class="events-grid">
        <% eventsList.slice(0, 4).forEach(function(event, i) { 
            const imgSrc = event.arquivo ? ('/uploads/eventos/' + event.arquivo) : ('/uploads/home/' + (event.arquivo || 'placeholder-event.jpg'));
            const linkUrl = event.arquivo ? `/eventos/${event.id}` : `/campanha/${event.id}`;
            const eventDate = event.data_evento ? (() => { const d = new Date(event.data_evento); return !isNaN(d.getTime()) ? d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) : ''; })() : '';
            const hasFotos = event.fotos && event.fotos.length > 0;
        %>
        <div class="event-card-hover">
            <div class="event-info">
                <h3 class="event-titulo" style="margin-bottom: 10px;"><%= event.titulo %></h3>
                <div class="event-meta">
                    <span><i class="fas fa-calendar-alt"></i> <%= eventDate %></span>
                    <% if (event.local) { %>
                    <span><i class="fas fa-map-marker-alt"></i> <%= event.local %></span>
                    <% } %>
                </div>
                <p class="event-descricao"><%= event.descricao && event.descricao.trim() ? event.descricao : 'Descrição não disponível.' %></p>
            </div>
            <div class="event-fotos-area">
                <% if (hasFotos) { %>
                    <% var primeiraFoto = event.fotos[0]; %>
                    <input type="checkbox" id="lightbox-event-<%= i %>" class="event-lightbox">
                    <label for="lightbox-event-<%= i %>" class="event-lightbox-trigger">
                        <img src="/uploads/eventos/<%= primeiraFoto.arquivo %>" alt="<%= event.titulo %>">
                    </label>
                    <div class="event-lightbox-overlay">
                        <label for="lightbox-event-<%= i %>" class="event-lightbox-close">&times;</label>
                        <% if (event.fotos.length > 1) { %>
                            <span class="event-lightbox-nav event-lightbox-prev">&#10094;</span>
                            <span class="event-lightbox-nav event-lightbox-next">&#10095;</span>
                        <% } %>
                        <div class="event-lightbox-content">
                            <img src="/uploads/eventos/<%= primeiraFoto.arquivo %>" alt="<%= event.titulo %>">
                        </div>
                        <div class="event-lightbox-counter">1 / <%= event.fotos.length %></div>
                    </div>
                <% } else { %>
                    <a href="<%= linkUrl %>">
                        <img src="<%= imgSrc %>" alt="<%= event.titulo %>">
                    </a>
                <% } %>
                <div class="event-fotos-overlay">
                    <span class="event-fotos-overlay-text">Clique para ampliar</span>
                </div>
            </div>
        </div>
        <% if (event.comentarios && event.comentarios.length > 0) { %>
