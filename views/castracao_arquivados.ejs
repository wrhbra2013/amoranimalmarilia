<%- include("_header") -%>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Castrações Arquivadas</h2>
        <a href="/home" class="btn btn-primary">Voltar ao Dashboard</a>
    </div>

    <% if (success_msg) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (error_msg) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Castrações Arquivadas -->
    <div class="card mb-4">
        <div class="card-header bg-warning">
            <h5 class="mb-0">Castrações</h5>
        </div>
        <div class="card-body">
            <% if (castracao && castracao.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Nome</th>
                                <th>Pet</th>
                                <th>Espécie</th>
                                <th>Clínica</th>
                                <th>Data</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% castracao.forEach(function(c) { %>
                                <tr>
                                    <td><%= c.ticket %></td>
                                    <td><%= c.nome %></td>
                                    <td><%= c.nome_pet || '-' %></td>
                                    <td><%= c.especie %></td>
                                    <td><%= c.clinica %></td>
                                    <td><%= c.origem ? new Date(c.origem).toLocaleDateString('pt-BR') : '-' %></td>
                                    <td>
                                        <form action="/castracao/desarquivar/<%= c.id %>" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-success btn-sm" title="Desarquivar">
                                                <i class="bi bi-archive-fill"></i> Restaurar
                                            </button>
                                        </form>
                                        <form action="/castracao/delete/<%= c.id %>" method="post" class="d-inline" onsubmit="return confirm('Excluir definitivamente?');">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="text-muted">Nenhuma castração arquivada.</p>
            <% } %>
        </div>
    </div>

    <!-- Mutirões Arquivados -->
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Mutirões</h5>
        </div>
        <div class="card-body">
            <% if (mutirao && mutirao.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Responsável</th>
                                <th>Clínica</th>
                                <th>Data</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% mutirao.forEach(function(m) { %>
                                <tr>
                                    <td><%= m.ticket %></td>
                                    <td><%= m.nome_responsavel %></td>
                                    <td><%= m.clinica || '-' %></td>
                                    <td><%= m.data_evento ? new Date(m.data_evento).toLocaleDateString('pt-BR') : (m.origem ? new Date(m.origem).toLocaleDateString('pt-BR') : '-') %></td>
                                    <td>
                                        <form action="/castracao/mutirao/desarquivar/<%= m.id %>" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-success btn-sm" title="Desarquivar">
                                                <i class="bi bi-archive-fill"></i> Restaurar
                                            </button>
                                        </form>
                                        <form action="/castracao/mutirao/delete/<%= m.id %>" method="post" class="d-inline" onsubmit="return confirm('Excluir definitivamente?');">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p class="text-muted">Nenhum mutirão arquivado.</p>
            <% } %>
        </div>
    </div>
</div>

<%- include("_footer") -%>
