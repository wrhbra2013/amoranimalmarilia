<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ONG Amor Animal Marilia.</title>
  <link rel="stylesheet" href="/static/css/default.css">
  <link rel="stylesheet" href="/static/css/imagem/bootstrap-icons.min.css">
  <link rel="icon" type="image/png" href="/static/css/favicon/ong.ico">
</head>

<body>
  <!-- High Contrast Toggle - CSS Pure -->
  <input type="checkbox" id="contrast-toggle" class="css-toggle-checkbox">
  <label for="contrast-toggle" class="contrast-label" aria-label="Alternar alto contraste">◧</label>

  <!-- Help Button - CSS Pure Dropdown -->
  <input type="checkbox" id="help-toggle" class="help-checkbox">
  <label for="help-toggle" class="help-label" aria-label="Ajuda">?</label>
  <div class="help-dropdown">
    <div class="help-content">
      <h4>Ajuda</h4>
      <p>Em caso de erros, dúvidas ou sugestões entre em contato conosco.</p>
      <hr>
      <h5>Erros comuns:</h5>
      <ul>
        <li><strong>Pet não adicionado:</strong> Preencha Nome, Espécie e Sexo do pet.</li>
        <li><strong>Inscrição não enviada:</strong> Verifique se todos os campos obrigatórios estão preenchidos.</li>
        <li><strong>Vagas esgotadas:</strong> O mutirão atingiu o limite de vagas.</li>
        <li><strong>Mutirão encerrado:</strong> As inscripciones foram encerradas após a data do evento.</li>
      </ul>
      <p>E deixe o seu melhor contato.</p>
      <p><strong>Email:</strong> <a href="mailto:amoranimalmariliadev@gmail.com">amoranimalmariliadev@gmail.com</a></p>
    </div>
  </div>

  <!-- Mobile Menu Toggle - must be directly before mobile-menu-wrapper for CSS ~ selector -->
  <input type="checkbox" id="mobile-menu-toggle" class="css-toggle-checkbox">
  <label for="mobile-menu-toggle" class="mobile-menu-button" aria-label="Abrir menu">
    <span></span>
  </label>

  <!-- Mobile Menu -->
  <div class="mobile-menu-wrapper">
    <nav class="mobile-menu">
      <ul class="nav-list">
        <li><a href="/home" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Início</a></li>
        <li><a href="/adocao" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Adoção</a></li>
        <li><a href="/adotado" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Adotados</a></li>
        <li><a href="/castracao" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Castração</a></li>
        <li><a href="/procura_se" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Procura-se</a></li>
        <li><a href="/doacao" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Doação</a></li>
        <%if (user) {%>
          <li><a href="/doacao/voluntario" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Voluntario</a></li>
          <li><a href="/doacao/coleta" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Coleta</a></li>
        <% } %>
        <li><a href="/parceria" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Parceria</a></li>
        <li><a href="/sobre" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Sobre</a></li>
        <li><a href="/transparencia" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Transparencia</a></li>
        <% if (user) { %>
          <li><a href="/admin/form" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Novo @admin</a></li>
          <li><a href="/relatorio/" onclick="document.getElementById('mobile-menu-toggle').checked = false;">Relatorios</a></li>
        <%}%>
      </ul>
    </nav>
  </div>

  <!-- Main Header and Navigation -->
  <header class="main-header">

    <main class="main-header-controls">
      <% if (user) { %>
        <span style="text-align: center; font-weight: bold;">Administrador<br>
          <a href="/auth/logout" class="login-button">Sair</a>
        </span>
      <% } else { %>
        <a href="/auth/login" class="login-button">Acesso</a>
      <% } %>
    </main>

    <div class="nav-container">
      <img src="/static/css/imagem/ong.jpg" alt="Logo ONG AMOR ANIMAL MARILIA" />
    </div>

    <div class="nav-wrapper">
      <nav class="main-nav">
        <ul class="nav-list">
          <li><a href="/home">Início</a></li>
          <li><a href="/adocao">Adoção</a></li>
          <li><a href="/adotado">Adotados</a></li>
          <li><a href="/castracao">Castração</a></li>
          <li><a href="/procura_se">Procura-se</a></li>
          <li><a href="/doacao">Doação</a></li>
          <%if (user) {%>
            <li><a href="/doacao/voluntario">Voluntario</a></li>
            <li><a href="/doacao/coleta">Coleta</a></li>
          <% } %>
          <li><a href="/parceria">Parceria</a></li>
          <li><a href="/sobre">Sobre</a></li>
          <li><a href="/transparencia">Transparencia</a></li>
          <% if (user) { %>
            <li><a href="/admin/form">Novo @admin</a></li>
            <li><a href="/relatorio/" class="login-button" style="text-align: center;">Relatorios</a></li>
          <%}%>
        </ul>
      </nav>
    </div>
  </header>

  <%- include('_cookie') %>
