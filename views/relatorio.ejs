 <link rel="stylesheet" href="/static/css/relatorio.css">
<%- include("_header") -%>

<%- include("_footer") -%>

<div class="relatorio-container">
      <!-- Painel de Banco de Dados (collapsible) -->
      <details class="db-panel-details">
          <summary class="db-panel-title">
              <i class="bi bi-hdd-stack me-2"></i>Painel do Banco de Dados
              <span class="warning-text">⚠️ Altere com cuidado, risco de perda de dados</span>
              <span class="db-panel-arrow">▼</span>
          </summary>
          
          <div class="db-panel-content">
              <div class="db-panel-actions">
                  <button type="button" class="btn-export btn-db" onclick="runBackup('run')">
                      <i class="bi bi-database-check"></i>
                      Criar Backup
                  </button>
                  <button type="button" class="btn-export btn-db btn-secondary" onclick="runBackup('cron')">
                      <i class="bi bi-clock-history"></i>
                      Agendar Backup (Cron)
                  </button>
                   <button type="button" class="btn-export btn-db btn-warning" onclick="showMaintenanceMenu()">
                        <i class="bi bi-tools"></i>
                        Manutenção (control.sh)
                    </button>
              </div>
              
              <div id="maintenanceMenu" class="maintenance-menu" style="display: none;">
                   <div class="menu-options">
                        <button type="button" class="menu-option" onclick="runMaintenance('1')">1) Fluxo Completo (Repo → NPM → PM2 → Nginx → Certif. → Logs)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('2')">2) Gerenciar Repositório</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('3')">3) Atualizar Código (Git Pull)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('4')">4) Instalar Dependências (NPM)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('5')">5) Reiniciar App (PM2)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('6')">6) Validar Webserver (Nginx)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('7')">7) Verificar Certificado (Certbot)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('8')">8) Renovar Certificado (Certbot)</button>
                        <button type="button" class="menu-option" onclick="runMaintenance('9')">9) Ver Logs</button>
                    </div>
              </div>
              
              <div class="log-container">
                  <label for="logOutput" class="form-label"><i class="bi bi-terminal me-2"></i>Logs:</label>
                  <textarea id="logOutput" class="form-control log-textarea" readonly placeholder="Aguardando ação..."></textarea>
                  <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="clearLog()">
                      <i class="bi bi-trash"></i> Limpar
                  </button>
              </div>
          </div>
      </details>

      <!-- Seletor de Tabelas do Banco de Dados -->
      <div class="selector-section mt-4">
          <h2 class="mb-3"><i class="bi bi-database me-2"></i>Selecionar Tabela</h2>
          <p class="text-muted">Escolha uma tabela do banco de dados para visualizar os dados</p>
          
          <div class="mb-3">
              <label for="tableSelect" class="form-label">Tabelas do Banco de Dados:</label>
              <select class="form-select" id="tableSelect" onchange="window.location.href='/relatorio/' + this.value">
                  <option value="">-- Selecione uma tabela --</option>
                  <% if (typeof todasTabelas !== 'undefined' && todasTabelas.length > 0) { %>
                      <% todasTabelas.forEach(function(table) { %>
                          <option value="<%= table %>" <%= (typeof tabela !== 'undefined' && tabela === table) ? 'selected' : '' %>>
                              <%= table %>
                          </option>
                      <% }); %>
                  <% } %>
              </select>
          </div>
          
          <div class="mb-3">
              <label for="backupSelect" class="form-label">Arquivo de Backup:</label>
              <div class="restore-controls">
                  <select class="form-select" id="backupSelect" style="flex: 1;">
                      <option value="">-- Selecione um backup --</option>
                  </select>
                  <button type="button" class="btn-export btn-db btn-restore" onclick="restoreTable()">
                      <i class="bi bi-arrow-counterclockwise"></i>
                      Restaurar
                  </button>
              </div>
          </div>

      <!-- Seção de Dados -->
      <% if (typeof tabela !== 'undefined' && tabela) { %>
         <div class="data-section">
             <div class="section-header">
                 <div>
                     <h1 class="section-title">
                         <% 
                         const reportTitles = {
                             'adocao': 'Adoção',
                             'adotante': 'Adotantes', 
                             'adotado': 'Adotados',
                             'castracao': 'Castração',
                             'procura_se': 'Procura-se',
                             'parceria': 'Parcerias',
                             'voluntario': 'Voluntários',
                             'interesse_voluntario': 'Interesse Voluntariado',
                             'interessados_adocao': 'Interesse Adoção',
                             'coleta': 'Coleta',
                             'login': 'Acessos ao Sistema'
                         };
                         const title = reportTitles[tabela] || tabela.charAt(0).toUpperCase() + tabela.slice(1);
                         %>
                         <i class="bi bi-database me-2"></i><%= title %>
                     </h1>
                 </div>
                 <div>
                     <span class="badge bg-light text-dark">
                         <%= typeof model !== 'undefined' && model.length ? model.length + ' registros' : '0 registros' %>
                     </span>
                 </div>
             </div>
             
              <% if (typeof model !== 'undefined' && model.length > 0) { %>
                  <div style="overflow-x: auto;">
                      <table class="table-modern">
                          <thead>
                              <% if (model.length > 0) { %>
                                  <tr>
                                      <% const firstItem = model[0]; %>
                                      <% for (const key in firstItem) { %>
                                          <% if (key === 'id') continue; %>
                                          <th>
                                              <%= key.charAt(0).toUpperCase() + key.slice(1).replace(/_/g, ' ').replace(/_formatado$/i, '') %>
                                          </th>
                                      <% } %>
                                      <th style="text-align: center; min-width: 100px;">Ações</th>
                                  </tr>
                              <% } %>
                          </thead>
                          <tbody>
                               <% for (const item of model) { %>
                                   <tr>
                                       <% for (const key in item) { %>
                                           <% if (key === 'id') continue; %>
                                           <td>
                                               <% 
                                               let val = item[key];
                                               if (val && typeof val === 'string' && val.length > 120) {
                                                   val = val.substring(0, 120) + '...';
                                               }
                                               %>
                                               <%= val || '-' %>
                                           </td>
                                       <% } %>
                                       <td>
                                           <% if (item.id) { %>
                                           <div class="action-buttons">
                                               <form action="/relatorio/delete/<%= tabela %>/<%= item.id %>?_method=DELETE" method="POST" style="margin: 0;">
                                                   <button type="submit" class="btn-action btn-delete" title="Excluir Registro" onclick="return confirm('Tem certeza que deseja excluir este registro? Esta ação não pode ser desfeita.')">
                                                       <i class="bi bi-trash"></i>
                                                   </button>
                                               </form>
                                           </div>
                                           <% } else { %>
                                           <span class="text-muted">-</span>
                                           <% } %>
                                       </td>
                                   </tr>
                               <% } %>
                          </tbody>
                      </table>
                  </div>
             <% } else { %>
                 <div class="empty-state">
                     <i class="bi bi-inbox"></i>
                     <h3>Nenhum Dado Encontrado</h3>
                     <p>Não há registros disponíveis para o relatório selecionado.</p>
                 </div>
             <% } %>
         </div>
         
         <!-- Seção de Exportação -->
         <% if (typeof model !== 'undefined' && model.length > 0) { %>
             <div class="export-section">
                 <form action="/relatorio/<%= tabela %>" method="post" style="margin: 0;">
                     <button type="submit" class="btn-export btn-pdf" onclick="return confirm('Gerar relatório PDF com todos os dados?');">
                         <i class="bi bi-file-earmark-pdf"></i>
                         Gerar Relatório PDF
                     </button>
                 </form>
                 
                 <a href="javascript:history.back()" class="btn-export" style="background: var(--button-bg); color: var(--button-text);">
                     <i class="bi bi-arrow-left"></i>
                     Voltar
                 </a>
             </div>
         <% } %>
     <% } else { %>
         <div class="data-section">
             <div class="empty-state">
                 <i class="bi bi-graph-up"></i>
                 <h3>Selecione um Relatório</h3>
                 <p>Escolha uma das opções acima para visualizar os dados correspondentes.</p>
             </div>
         </div>
     <% } %>
</div>

<script src="/static/js/relatorio.js"></script>

<%- include("_footer") -%>
 