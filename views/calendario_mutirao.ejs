<%- include("_header") -%>

<main class="container mt-4">
  <% if (user){ %>
  <h1>Calendário de Mutirão</h1>
  <p class="text-muted">Criar, listar e gerenciar datas disponíveis para mutirões de castração.</p>

  <% if (error && error.length) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success && success.length) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <section class="card mb-4 p-3">
    <form action="/castracao/calendario-mutirao" method="POST" class="row g-2">
      <div class="col-md-3">
        <label class="form-label">Data</label>
        <input type="date" name="data_evento" class="form-control" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Clínica</label>
        <select name="clinica" id="clinicaSelect" class="form-select" required onchange="updateEndereco()">
          <option value="">Selecione uma clínica...</option>
          <% if (typeof clinicas !== 'undefined' && clinicas.length > 0) { %>
            <% clinicas.forEach(function(clinica) { %>
              <option value="<%= clinica.nome %>" data-endereco="<%= clinica.endereco || '' %>"><%= clinica.nome %></option>
            <% }); %>
          <% } %>
        </select>
        <a href="/clinicas/form" target="_blank" class="small text-primary">+ Cadastrar Nova Clínica</a>
      </div>
      <div class="col-md-3">
        <label class="form-label">Endereço</label>
        <input type="text" name="endereco" id="enderecoInput" class="form-control" placeholder="Selecione a clínica">
      </div>
      <div class="col-md-2">
        <label class="form-label">Vagas</label>
        <input type="number" name="vagas" class="form-control" value="10" min="0" title="0 = vagas ilimitadas">
        <small class="text-muted">0 = ilimitadas</small>
      </div>
      <div class="col-md-12 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="submit">Adicionar Data</button>
      </div>
    </form>
  </section>

  <script>
    function updateEndereco() {
      const select = document.getElementById('clinicaSelect');
      const enderecoInput = document.getElementById('enderecoInput');
      const selectedOption = select.options[select.selectedIndex];
      const endereco = selectedOption.getAttribute('data-endereco');
      
      if (endereco) {
        enderecoInput.value = endereco;
      } else {
        enderecoInput.value = '';
      }
    }
  </script>
  <% } %>
  <section>
    <h3>Datas de Mutirão Agendadas</h3>
    <% if (calendario && calendario.length > 0) { %>
      <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
        <table class="table table-striped table-hover">
          <thead class="sticky-top">
            <tr><th>Data</th><th>Clínica</th><th>Endereço</th><th>Vagas</th><th>Disponíveis</th><th>Ações</th><th>Criado em</th><th></th><th></th></tr>
          </thead>
          <tbody>
          <% calendario.forEach(function(c){ %>
            <tr>
              <td><%= c.data_evento ? new Date(c.data_evento).toLocaleDateString('pt-BR') : '' %></td>
              <td><%= c.clinica %></td>
              <td style="white-space: pre-line; max-width: 150px;"><%= c.endereco || '-' %></td>
              <td><%= c.vagas === 0 ? 'Ilimitadas' : c.vagas %></td>
              <td>
                <% if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 0) { %>
                  <span class="badge bg-danger">Vagas Esgotadas</span>
                <% } else if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 3) { %>
                  <span class="badge bg-warning text-dark"><%= c.vagas_disponiveis %></span>
                <% } else { %>
                  <span class="badge bg-success"><%= c.vagas_disponiveis !== undefined ? (c.vagas_disponiveis === null ? 'Ilimitadas' : c.vagas_disponiveis) : (c.vagas === 0 ? 'Ilimitadas' : c.vagas) %></span>
                <% } %>
              </td>
              <td>
                <% if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 0) { %>
                  <button class="btn btn-sm btn-outline-secondary" disabled>
                    <i class="fas fa-user-plus"></i> Esgotado
                  </button>
                <% } else { %>
                  <a href="/castracao/mutirao-inscricao/<%= c.id %>" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-user-plus"></i> Inscrever
                  </a>
                <% } %>
                </td>
                 <td><%= c.created_at ? new Date(c.created_at).toLocaleString('pt-BR') : '' %></td>
                <td>
                <% if (user) { %>
                  <a href="/castracao/calendario-mutirao/relatorio/<%= c.id %>" class="btn btn-sm btn-info ms-1" title="Gerar Relatório">
                    <i class="fas fa-file-pdf">Relatorio</i>
                  </a>
                  <form action="/castracao/calendario-mutirao/arquivar/<%= c.id %>" method="POST" class="d-inline"
                        onsubmit="return confirm('Arquivar este mutirão?')">
                    <button type="submit" class="btn btn-sm btn-warning ms-1" title="Arquivar Mutirão">
                      <i class="bi bi-archive">Arquivar</i>
                    </button>
                  </form>
                  </td>
                 <td>
                  <form action="/castracao/calendario-mutirao/delete/<%= c.id %>" method="POST" class="d-inline"
                        onsubmit="return confirm('Tem certeza que deseja excluir este mutirão e todas as inscrições relacionadas?')">
                    <button type="submit" class="btn btn-sm btn-danger ms-1" title="Excluir Mutirão">
                      <i class="bi bi-trash">Excluir</i>
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      </div>
    <% } else { %>
      <p class="text-muted">Nenhuma data de mutirão cadastrada.</p>
    <% } %>
  </section>

  <% if (user) { %>
  <section class="mt-4">
    <h3>Mutirões Arquivados</h3>
    <% if (arquivados && arquivados.length > 0) { %>
      <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
        <table class="table table-striped table-hover">
          <thead class="sticky-top">
            <tr><th>Data</th><th>Clínica</th><th>Endereço</th><th>Vagas</th><th>Ações</th></tr>
          </thead>
          <tbody>
          <% arquivados.forEach(function(c){ %>
            <tr>
              <td><%= c.data_evento ? new Date(c.data_evento).toLocaleDateString('pt-BR') : '' %></td>
              <td><%= c.clinica %></td>
              <td><%= c.endereco || '-' %></td>
              <td><%= c.vagas === 0 ? 'Ilimitadas' : c.vagas %></td>
              <td>
                <form action="/castracao/calendario-mutirao/desarquivar/<%= c.id %>" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-success" title="Restaurar">
                    <i class="bi bi-archive-fill">Restaurar</i>
                  </button>
                </form>
                <form action="/castracao/calendario-mutirao/delete/<%= c.id %>" method="POST" class="d-inline"
                      onsubmit="return confirm('Excluir definitivamente?')">
                  <button type="submit" class="btn btn-sm btn-danger" title="Excluir">
                    <i class="bi bi-trash">Excluir</i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-muted">Nenhum mutirão arquivado.</p>
    <% } %>
  </section>
  <% } %>

</main>

<%- include("_footer") -%>
