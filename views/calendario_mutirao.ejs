<%- include("_header") -%>

<main class="container mt-4">
  <% if (user && user.isAdmin){ %>
  <h1>Calendário de Mutirão</h1>
  <p class="text-muted">Criar, listar e gerenciar datas disponíveis para mutirões de castração.</p>

  <% if (error && error.length) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success && success.length) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <!-- Seção para definir clínica padrão para mutirões (Admin) -->
  <section class="card mb-4 p-3 bg-light">
    <h5 class="mb-3"><i class="bi bi-hospital me-2"></i>Clínica Padrão para Mutirões (Modo Administrador)</h5>
    <p class="text-muted small">Esta clínica será automaticamente preenchida nos formulários de inscrição.</p>
    <form action="/castracao/calendario-mutirao/salvar-default-clinica" method="POST" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label">Selecione a clínica</label>
        <select name="defaultClinicaMutirao" id="defaultClinicaMutirao" class="form-select" onchange="updateDefaultEndereco()">
          <option value="">-- Nenhuma (A definir) --</option>
          <% if (typeof clinicas !== 'undefined' && clinicas.length > 0) { %>
            <% clinicas.forEach(function(clinica) { %>
              <option value="<%= clinica.nome %>" data-endereco="<%= clinica.endereco || '' %>" <%= (typeof defaultClinicaMutirao !== 'undefined' && defaultClinicaMutirao === clinica.nome) ? 'selected' : '' %>><%= clinica.nome %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Endereço</label>
        <div id="defaultClinicaMutiraoEndereco" class="form-control-plaintext">
          <%= (typeof defaultClinicaMutiraoEndereco !== 'undefined' && defaultClinicaMutiraoEndereco) ? defaultClinicaMutiraoEndereco : (typeof defaultClinicaMutirao !== 'undefined' && defaultClinicaMutirao ? 'Endereço não cadastrado' : '— A definir —') %>
        </div>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">Salvar Clínica Padrão</button>
      </div>
    </form>
  </section>

  <script>
    function updateDefaultEndereco() {
      const select = document.getElementById('defaultClinicaMutirao');
      const enderecoDiv = document.getElementById('defaultClinicaMutiraoEndereco');
      const selectedOption = select.options[select.selectedIndex];
      const endereco = selectedOption.getAttribute('data-endereco');
      
      if (endereco) {
        enderecoDiv.textContent = endereco;
      } else if (select.value) {
        enderecoDiv.textContent = 'Endereço não cadastrado';
      } else {
        enderecoDiv.textContent = '— A definir —';
      }
    }
  </script>

  <section class="card mb-4 p-3">
    <h5 class="mb-3"><i class="bi bi-calendar-plus me-2"></i>Adicionar Nova Data de Mutirão</h5>
    <form action="/castracao/calendario-mutirao" method="POST" class="row g-2">
      <div class="col-md-3">
        <label class="form-label">Data</label>
        <input type="date" name="data_evento" class="form-control" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Clínica</label>
        <select name="clinica" id="clinicaSelect" class="form-select" required onchange="updateEndereco()">
          <option value="">Selecione uma clínica...</option>
          <% if (typeof clinicas !== 'undefined' && clinicas.length > 0) { %>
            <% clinicas.forEach(function(clinica) { %>
              <option value="<%= clinica.nome %>" data-endereco="<%= clinica.endereco || '' %>" <%= (typeof defaultClinicaMutirao !== 'undefined' && defaultClinicaMutirao === clinica.nome) ? 'selected' : '' %>><%= clinica.nome %></option>
            <% }); %>
          <% } %>
        </select>
        <a href="/clinicas/form" target="_blank" class="small text-primary">+ Cadastrar Nova Clínica</a>
      </div>
      <div class="col-md-3">
        <label class="form-label">Endereço</label>
        <input type="text" name="endereco" id="enderecoInput" class="form-control" placeholder="Selecione a clínica" value="<%= typeof defaultClinicaMutiraoEndereco !== 'undefined' ? defaultClinicaMutiraoEndereco : '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">Vagas</label>
        <input type="number" name="vagas" class="form-control" value="10" min="0" title="0 = vagas ilimitadas">
        <small class="text-muted">0 = ilimitadas</small>
      </div>
      <div class="col-md-12 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="submit">Adicionar Data</button>
      </div>
    </form>
  </section>

  <script>
    function updateEndereco() {
      const select = document.getElementById('clinicaSelect');
      const enderecoInput = document.getElementById('enderecoInput');
      const selectedOption = select.options[select.selectedIndex];
      const endereco = selectedOption.getAttribute('data-endereco');
      
      if (endereco) {
        enderecoInput.value = endereco;
      } else {
        enderecoInput.value = '';
      }
    }
    
    // Atualizar endereço ao carregar a página se a clínica padrão estiver selecionada
    document.addEventListener('DOMContentLoaded', function() {
      if (document.getElementById('clinicaSelect').value) {
        updateEndereco();
      }
    });
  </script>
  <% } %>
  
  <% if (!user || !user.isAdmin) { %>
  <h1>Calendário de Mutirão</h1>
  <p class="text-muted">Datas disponíveis para mutirões de castração.</p>
  <% } %>
  
  <section>
    <h3>Datas de Mutirão Agendadas</h3>
    <% if (calendario && calendario.length > 0) { %>
      <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
        <table class="table table-striped table-hover">
          <thead class="sticky-top bg-light">
            <tr>
              <th>Data</th>
              <th>Clínica</th>
              <th>Endereço</th>
              <th>Vagas</th>
              <th>Disponíveis</th>
              <th>Inscrever</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
          <% calendario.forEach(function(c){ %>
            <tr>
              <td><%= c.data_evento ? (typeof c.data_evento === 'string' ? c.data_evento : (() => { const d = new Date(c.data_evento); return !isNaN(d.getTime()) ? d.toLocaleDateString('pt-BR') : ''; })()) : '' %></td>
              <td><%= c.clinica %></td>
              <td style="white-space: pre-line; max-width: 150px;"><%= c.endereco || '-' %></td>
              <td><%= c.vagas === 0 ? 'Ilimitadas' : c.vagas %></td>
              <td>
                <% 
                  const hoje = new Date();
                  hoje.setHours(0, 0, 0, 0);
                  const dataEventoVal = typeof c.data_evento === 'string' ? (() => { const parts = c.data_evento.split('/'); return parts.length === 3 ? new Date(parts[2], parts[1]-1, parts[0]) : new Date(c.data_evento); })() : c.data_evento;
                  const dataEvento = new Date(dataEventoVal);
                  const expirado = !isNaN(dataEvento.getTime()) && dataEvento <= hoje;
                %>
                <% if (expirado) { %>
                  <span class="badge bg-secondary">Encerrado</span>
                <% } else if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 0) { %>
                  <span class="badge bg-danger">Esgotadas</span>
                <% } else if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 3) { %>
                  <span class="badge bg-warning text-dark"><%= c.vagas_disponiveis %></span>
                <% } else { %>
                  <span class="badge bg-success"><%= c.vagas_disponiveis !== undefined ? (c.vagas_disponiveis === null ? 'Ilimitadas' : c.vagas_disponiveis) : (c.vagas === 0 ? 'Ilimitadas' : c.vagas) %></span>
                <% } %>
              </td>
              <td>
                <% if (expirado) { %>
                  <button class="btn btn-sm btn-outline-secondary" disabled>
                    <i class="fas fa-times"></i> Encerrado
                  </button>
                <% } else if (c.vagas_disponiveis !== null && c.vagas_disponiveis <= 0) { %>
                  <button class="btn btn-sm btn-outline-secondary" disabled>
                    <i class="fas fa-user-plus"></i> Esgotado
                  </button>
                <% } else { %>
                  <a href="/castracao/mutirao-inscricao/<%= c.id %>" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-user-plus"></i> Inscrever
                  </a>
                <% } %>
              </td>
              <td><%= c.created_at ? (typeof c.created_at === 'string' ? c.created_at : (() => { const d = new Date(c.created_at); return !isNaN(d.getTime()) ? d.toLocaleString('pt-BR') : ''; })()) : '' %></td>
              <td>
                <% if (user) { %>
                  <a href="/castracao/calendario-mutirao/relatorio/<%= c.id %>" class="btn btn-sm btn-info" title="Gerar Relatório PDF">
                    <i class="fas fa-file-pdf"></i> Relatório
                  </a>
                <% } %>
                <% if (user) { %>
                  <form action="/castracao/calendario-mutirao/delete/<%= c.id %>" method="POST" class="d-inline"
                        onsubmit="return confirm('Tem certeza que deseja excluir este mutirão e todas as inscrições relacionadas?')">
                    <button type="submit" class="btn btn-sm btn-danger" title="Excluir Mutirão">
                      excluir
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      </div>
    <% } else { %>
      <p class="text-muted">Nenhuma data de mutirão cadastrada.</p>
    <% } %>
  </section>

</main>

<%- include("_footer") -%>
